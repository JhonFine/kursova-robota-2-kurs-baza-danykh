<Window x:Class="CarRental.Desktop.Views.Windows.RentalsPaymentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CarRental.Desktop.Models"
        Title="Оренди: платежі та календар"
        Width="1280"
        Height="840"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="1.6*" />
            <RowDefinition Height="1.3*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock DockPanel.Dock="Left"
                       Text="Платежі та завантаженість автопарку"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button DockPanel.Dock="Right"
                    Content="Оновити"
                    Padding="14,8"
                    Command="{Binding RefreshCommand}" />
        </DockPanel>

        <GroupBox Grid.Row="1" Header="Оберіть оренду для роботи з платежами" Padding="12" Margin="0,0,0,10">
            <DataGrid ItemsSource="{Binding Rentals}"
                      SelectedItem="{Binding SelectedRental}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                    <DataGridTextColumn Header="Договір" Binding="{Binding ContractNumber}" Width="120" />
                    <DataGridTextColumn Header="Клієнт" Binding="{Binding ClientName}" Width="170" />
                    <DataGridTextColumn Header="Авто" Binding="{Binding VehicleName}" Width="160" />
                    <DataGridTextColumn Header="Початок" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="100" />
                    <DataGridTextColumn Header="Кінець" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="100" />
                    <DataGridTextColumn Header="Сума" Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Width="100" />
                    <DataGridTextColumn Header="Сплачено" Binding="{Binding PaidAmount, StringFormat={}{0:C}}" Width="100" />
                    <DataGridTextColumn Header="Залишок" Binding="{Binding Balance, StringFormat={}{0:C}}" Width="100" />
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Платежі (готівка/карта, надходження/повернення)" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0"
                         Grid.Column="0"
                         Margin="0,0,6,8"
                         Text="{Binding PaymentAmountInput, UpdateSourceTrigger=PropertyChanged}" />
                <ComboBox Grid.Row="0"
                          Grid.Column="1"
                          Margin="0,0,6,8"
                          SelectedValue="{Binding PaymentMethod}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="Готівка" Tag="{x:Static models:PaymentMethod.Cash}" />
                    <ComboBoxItem Content="Карта" Tag="{x:Static models:PaymentMethod.Card}" />
                </ComboBox>
                <ComboBox Grid.Row="0"
                          Grid.Column="2"
                          Margin="0,0,6,8"
                          SelectedValue="{Binding PaymentDirection}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="Надходження" Tag="{x:Static models:PaymentDirection.Incoming}" />
                    <ComboBoxItem Content="Повернення" Tag="{x:Static models:PaymentDirection.Refund}" />
                </ComboBox>
                <Button Grid.Row="0"
                        Grid.Column="3"
                        Width="90"
                        Content="Додати"
                        Command="{Binding AddPaymentCommand}" />

                <DataGrid Grid.Row="1"
                          Grid.ColumnSpan="4"
                          ItemsSource="{Binding Payments}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAtUtc, StringFormat=HH:mm:ss dd.MM}" Width="130" />
                        <DataGridTextColumn Header="Метод" Binding="{Binding MethodDisplay}" Width="110" />
                        <DataGridTextColumn Header="Напрям" Binding="{Binding DirectionDisplay}" Width="110" />
                        <DataGridTextColumn Header="Сума" Binding="{Binding Amount, StringFormat={}{0:C}}" Width="100" />
                        <DataGridTextColumn Header="Примітки" Binding="{Binding Notes}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Gantt (компактна шкала на 14 днів)" Padding="12" Margin="0,0,0,10">
            <DataGrid ItemsSource="{Binding GanttRows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Авто" Binding="{Binding Vehicle}" Width="300" />
                    <DataGridTextColumn Header="Шкала (A=Активна, B=Бронь, .=Вільно)" Binding="{Binding Timeline}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Border Grid.Row="4" Background="#E2E8F0" CornerRadius="6" Padding="10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#0F172A" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
