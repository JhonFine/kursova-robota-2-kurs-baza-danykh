<Window x:Class="CarRental.Desktop.Views.Windows.RentalsManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оренди: договори та статуси"
        Width="1260"
        Height="820"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock DockPanel.Dock="Left"
                       Text="Оформлення та керування договорами оренди"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button DockPanel.Dock="Right"
                    Content="Оновити"
                    Padding="14,8"
                    Command="{Binding RefreshCommand}" />
        </DockPanel>

        <GroupBox Grid.Row="1" Header="Створення бронювання/оренди" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Клієнт" Margin="0,0,0,4" />
                <ComboBox Grid.Row="1" Grid.Column="0" Margin="0,0,10,0"
                          ItemsSource="{Binding Clients}"
                          DisplayMemberPath="Display"
                          SelectedItem="{Binding SelectedClient}"
                          Text="{Binding ClientSearchText, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          MaxDropDownHeight="360" />

                <TextBlock Grid.Row="0" Grid.Column="1" Text="Авто" Margin="0,0,0,4" />
                <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,0,10,0"
                          ItemsSource="{Binding Vehicles}"
                          DisplayMemberPath="Display"
                          SelectedItem="{Binding SelectedVehicle}"
                          Text="{Binding VehicleSearchText, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          MaxDropDownHeight="360" />

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Початок" Margin="0,0,0,4" />
                <DatePicker Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,0,10,0"
                            DisplayDateStart="{Binding MinCreateStartDate, Mode=OneWay}"
                            SelectedDate="{Binding StartDate}" />
                <TextBlock Grid.Row="2"
                           Grid.Column="2"
                           Margin="0,4,10,0"
                           Foreground="#B91C1C"
                           Text="{Binding CreateStartDateValidationMessage}"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasCreateStartDateValidationMessage, Converter={StaticResource BoolToVisibilityConverter}}" />

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Кінець" Margin="0,0,0,4" />
                <DatePicker Grid.Row="1"
                            Grid.Column="3"
                            Margin="0,0,10,0"
                            DisplayDateStart="{Binding MinCreateEndDate, Mode=OneWay}"
                            SelectedDate="{Binding EndDate}" />
                <TextBlock Grid.Row="2"
                           Grid.Column="3"
                           Margin="0,4,10,0"
                           Foreground="#B91C1C"
                           Text="{Binding CreateEndDateValidationMessage}"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasCreateEndDateValidationMessage, Converter={StaticResource BoolToVisibilityConverter}}" />

                <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal">
                    <Button Content="Створити"
                            Width="100"
                            Height="34"
                            Margin="0,0,8,0"
                            Command="{Binding CreateRentalCommand}" />
                    <CheckBox Content="Автодрук PDF"
                              IsChecked="{Binding AutoPrintContract}"
                              VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Оренди та бронювання" Padding="12" Margin="0,0,0,10">
            <DataGrid ItemsSource="{Binding Rentals}"
                      SelectedItem="{Binding SelectedRental}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                    <DataGridTextColumn Header="Договір" Binding="{Binding ContractNumber}" Width="120" />
                    <DataGridTextColumn Header="Клієнт" Binding="{Binding ClientName}" Width="180" />
                    <DataGridTextColumn Header="Авто" Binding="{Binding VehicleName}" Width="170" />
                    <DataGridTextColumn Header="Початок" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="105" />
                    <DataGridTextColumn Header="Кінець" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}" Width="105" />
                    <DataGridTextColumn Header="Сума" Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Width="110" />
                    <DataGridTextColumn Header="Сплачено" Binding="{Binding PaidAmount, StringFormat={}{0:C}}" Width="110" />
                    <DataGridTextColumn Header="Залишок" Binding="{Binding Balance, StringFormat={}{0:C}}" Width="110" />
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Закриття оренди" Padding="10" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Дата повернення" Margin="0,0,0,4" />
                    <DatePicker Grid.Row="1" Margin="0,0,0,8" SelectedDate="{Binding ActualReturnDate}" />
                    <TextBlock Grid.Row="2" Text="Кінцевий пробіг" Margin="0,0,0,4" />
                    <TextBox Grid.Row="3" Margin="0,0,0,8" Text="{Binding EndMileageInput, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Row="4" Content="Закрити оренду" Height="32" Command="{Binding CloseRentalCommand}" />
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="Скасування оренди" Padding="10" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Причина скасування" Margin="0,0,0,4" />
                    <TextBox Margin="0,0,0,8" Text="{Binding CancelReason, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Скасувати оренду" Height="32" Command="{Binding CancelRentalCommand}" />
                </StackPanel>
            </GroupBox>
        </Grid>

        <Border Grid.Row="4" Background="#E2E8F0" CornerRadius="6" Padding="10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#0F172A" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
