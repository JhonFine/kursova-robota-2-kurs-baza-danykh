<Window x:Class="CarRental.Desktop.Views.Windows.AddVehicleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додати авто"
        Width="920"
        Height="760"
        MinWidth="760"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardSurfaceStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0"
                              Margin="0,0,14,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Параметри майбутнього авто" Style="{StaticResource SectionTitleStyle}" FontSize="17" />
                        <TextBlock Text="Заповніть детальні дані, які будуть додані до бази даних автопарку."
                                   Style="{StaticResource SectionHintStyle}"
                                   Margin="0,4,0,12" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                                <TextBlock Style="{StaticResource FormLabelStyle}" Text="Марка" />
                                <TextBox Text="{Binding Make, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                                <TextBlock Style="{StaticResource FormLabelStyle}" Text="Модель" />
                                <TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                                <TextBlock Style="{StaticResource FormLabelStyle}" Text="Двигун / батарея" />
                                <TextBox Text="{Binding EngineDisplay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                                <TextBlock Style="{StaticResource FormLabelStyle}" Text="Тип пального" />
                                <TextBox Text="{Binding FuelType, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,10">
                                <TextBlock Style="{StaticResource FormLabelStyle}" Text="Коробка передач" />
                                <TextBox Text="{Binding TransmissionType, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                                <TextBlock Style="{StaticResource FormLabelStyle}" Text="Кількість дверей" />
                                <TextBox Text="{Binding DoorsCount, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,10">
                                <TextBlock Style="{StaticResource FormLabelStyle}" Text="Місткість / багажник" />
                                <TextBox Text="{Binding CargoCapacityDisplay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,10">
                                <TextBlock Style="{StaticResource FormLabelStyle}" Text="Витрата / споживання" />
                                <TextBox Text="{Binding ConsumptionDisplay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,10,10">
                                <TextBlock Style="{StaticResource FormLabelStyle}" Text="Держ. номер" />
                                <TextBox Text="{Binding LicensePlate, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,10">
                                <TextBlock Style="{StaticResource FormLabelStyle}" Text="Пробіг" />
                                <TextBox Text="{Binding Mileage, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,10,10">
                                <TextBlock Style="{StaticResource FormLabelStyle}" Text="Ціна за добу" />
                                <TextBox Text="{Binding DailyRate, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,0,0,10">
                                <TextBlock Style="{StaticResource FormLabelStyle}" Text="Інтервал ТО (км)" />
                                <TextBox Text="{Binding ServiceIntervalKm, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <CheckBox Grid.Row="6"
                                      Grid.ColumnSpan="2"
                                      Margin="0,2,0,0"
                                      IsChecked="{Binding HasAirConditioning}"
                                      Content="У комплектації є A/C" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1"
                        Background="#F8FAFC"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10">
                    <Grid>
                        <Image Source="{Binding PhotoPath}"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPhoto}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>

                        <TextBlock Text="Фото ще не додано"
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPhoto}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Вибрати фото"
                    Click="ChoosePhotoButton_OnClick" />
            <Button Content="Очистити фото"
                    Margin="8,0,0,0"
                    Click="ClearPhotoButton_OnClick" />
        </StackPanel>

        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Style="{StaticResource StatusPanelStyle}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Text="{Binding ValidationMessage}"
                           Foreground="{StaticResource DangerBrush}" />

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Скасувати"
                            Margin="0,0,8,0"
                            IsCancel="True" />
                    <Button Content="Додати авто"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="SaveButton_OnClick" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
