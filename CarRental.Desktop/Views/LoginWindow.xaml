<Window x:Class="CarRental.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вхід"
        Width="740"
        Height="760"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="LoginWindow_OnLoaded">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <DrawingBrush x:Key="LoginPatternBrush"
                      Viewport="0,0,180,180"
                      ViewportUnits="Absolute"
                      TileMode="Tile">
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#142A6C80" Thickness="1" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,90" EndPoint="180,90" />
                            <LineGeometry StartPoint="90,0" EndPoint="90,180" />
                            <LineGeometry StartPoint="0,0" EndPoint="180,180" />
                            <LineGeometry StartPoint="180,0" EndPoint="0,180" />
                            <EllipseGeometry Center="90,90" RadiusX="84" RadiusY="84" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="WindowCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#D7ECF3" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseButtonBorder" Property="Background" Value="#1E95B0" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CloseButtonBorder" Property="Background" Value="#17758D" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#182A35" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="InputChromeStyle" TargetType="Border">
            <Setter Property="Background" Value="#D9ECF8" />
            <Setter Property="BorderBrush" Value="#A8C8D8" />
            <Setter Property="BorderThickness" Value="1.4" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Height" Value="62" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#260A4154"
                                      BlurRadius="10"
                                      ShadowDepth="1"
                                      Opacity="0.5" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#53D4B4" />
                    <Setter Property="Background" Value="#EAF6FC" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#6B2ED8C5"
                                              BlurRadius="18"
                                              ShadowDepth="0"
                                              Opacity="0.75" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmallInputChromeStyle"
               TargetType="Border"
               BasedOn="{StaticResource InputChromeStyle}">
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#213340" />
            <Setter Property="FontSize" Value="17" />
        </Style>

        <Style x:Key="InputPasswordStyle" TargetType="PasswordBox">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#213340" />
            <Setter Property="FontSize" Value="17" />
        </Style>

        <Style x:Key="ActionButtonBaseStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="56" />
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1.6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonBaseStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#1D5A6A" />
            <Setter Property="BorderBrush" Value="#CBD5DF" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#1E173047"
                                      BlurRadius="14"
                                      ShadowDepth="1"
                                      Opacity="0.3" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RegisterButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonBaseStyle}">
            <Setter Property="Background" Value="#FBFFFE" />
            <Setter Property="Foreground" Value="#165B6D" />
            <Setter Property="BorderBrush" Value="#198D95" />
        </Style>

        <Style x:Key="LoginButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonBaseStyle}">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#178A6E" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0E9078" Offset="0" />
                        <GradientStop Color="#67E3A6" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#3A19B98F"
                                      BlurRadius="18"
                                      ShadowDepth="0"
                                      Opacity="0.6" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#5F8EA2">
        <Border Margin="28"
                BorderThickness="2"
                BorderBrush="#629AAE"
                CornerRadius="22">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#146B89" Offset="0" />
                    <GradientStop Color="#0A536E" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="62" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="16,0,14,0"
                      MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38"
                                Height="38"
                                Margin="0,0,12,0"
                                CornerRadius="19">
                            <Border.Background>
                                <RadialGradientBrush Center="0.4,0.3" RadiusX="0.8" RadiusY="0.8">
                                    <GradientStop Color="#CDF8E2" Offset="0" />
                                    <GradientStop Color="#5CB19F" Offset="1" />
                                </RadialGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#xE8D8;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="20"
                                       Foreground="#F7FFFD"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Вхід"
                                   Foreground="#E9F7FA"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource WindowCloseButtonStyle}"
                            Content="&#xE711;"
                            Click="CloseButton_OnClick" />
                </Grid>

                <Border Grid.Row="1"
                        Margin="14,0,14,14"
                        CornerRadius="20"
                        BorderThickness="1"
                        BorderBrush="#DCE8EE"
                        Background="#FBFAF6">
                    <Grid>
                        <Rectangle Fill="{StaticResource LoginPatternBrush}"
                                   Opacity="0.2"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   IsHitTestVisible="False" />

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="30,24,30,28">
                                <TextBlock Text="Вхід у систему"
                                           FontSize="52"
                                           FontWeight="Bold"
                                           Foreground="#273443" />
                                <TextBlock Text="Увійдіть або зареєструйте новий обліковий запис."
                                           Margin="0,6,0,24"
                                           FontSize="17"
                                           Foreground="#4D6070" />

                                <Border Margin="0,0,0,16"
                                        Padding="16,14,16,8"
                                        CornerRadius="14"
                                        BorderBrush="#D8E8EE"
                                        BorderThickness="1"
                                        Background="#F3FAFC"
                                        Visibility="{Binding IsRegistrationMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Прізвище" Style="{StaticResource InputLabelStyle}" />
                                            <TextBlock Grid.Column="1" Margin="10,0,0,8" Text="Ім'я" Style="{StaticResource InputLabelStyle}" />
                                            <TextBlock Grid.Column="2" Margin="10,0,0,8" Text="По батькові" Style="{StaticResource InputLabelStyle}" />
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Margin="0,0,10,10"
                                                    Style="{StaticResource SmallInputChromeStyle}">
                                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                         Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" />
                                            </Border>
                                            <Border Grid.Column="1"
                                                    Margin="0,0,10,10"
                                                    Style="{StaticResource SmallInputChromeStyle}">
                                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                         Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" />
                                            </Border>
                                            <Border Grid.Column="2"
                                                    Margin="0,0,0,10"
                                                    Style="{StaticResource SmallInputChromeStyle}">
                                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                         Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}" />
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="Телефон"
                                                   Margin="0,8,0,8"
                                                   Style="{StaticResource InputLabelStyle}" />
                                        <Border Style="{StaticResource SmallInputChromeStyle}">
                                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Логін для входу" Style="{StaticResource InputLabelStyle}" />
                                <Border Style="{StaticResource InputChromeStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE77B;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="21"
                                                   Foreground="#375B6A"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,14,0" />
                                        <Grid Grid.Column="1">
                                            <TextBox x:Name="LoginTextBox"
                                                     Margin="0"
                                                     Style="{StaticResource InputTextBoxStyle}"
                                                     Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="username or email"
                                                       VerticalAlignment="Center"
                                                       Foreground="#4F616E"
                                                       FontSize="17"
                                                       IsHitTestVisible="False">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, ElementName=LoginTextBox}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <TextBlock Text="Пароль" Margin="0,16,0,8" Style="{StaticResource InputLabelStyle}" />
                                <Border Style="{StaticResource InputChromeStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE72E;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="21"
                                                   Foreground="#375B6A"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,14,0" />
                                        <Grid Grid.Column="1">
                                            <PasswordBox x:Name="PasswordInput"
                                                         Style="{StaticResource InputPasswordStyle}"
                                                         PasswordChanged="PasswordBox_OnPasswordChanged" />
                                            <TextBlock x:Name="PasswordPlaceholder"
                                                       Text="••••••••"
                                                       VerticalAlignment="Center"
                                                       Foreground="#4F616E"
                                                       FontSize="17"
                                                       IsHitTestVisible="False"
                                                       Visibility="Visible" />
                                        </Grid>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="0,16,0,0"
                                            Visibility="{Binding IsRegistrationMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Повторити пароль" Style="{StaticResource InputLabelStyle}" />
                                    <Border Style="{StaticResource InputChromeStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE72E;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="21"
                                                       Foreground="#375B6A"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,14,0" />
                                            <Grid Grid.Column="1">
                                                <PasswordBox x:Name="ConfirmPasswordInput"
                                                             Style="{StaticResource InputPasswordStyle}"
                                                             PasswordChanged="ConfirmPasswordBox_OnPasswordChanged" />
                                                <TextBlock x:Name="ConfirmPasswordPlaceholder"
                                                           Text="••••••••"
                                                           VerticalAlignment="Center"
                                                           Foreground="#4F616E"
                                                           FontSize="17"
                                                           IsHitTestVisible="False"
                                                           Visibility="Visible" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <TextBlock Text="{Binding ErrorMessage}"
                                           Height="26"
                                           Margin="0,12,0,0"
                                           Foreground="#C02626"
                                           FontSize="18"
                                           FontWeight="SemiBold" />

                                <Grid Margin="0,22,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="1"
                                            Style="{StaticResource CancelButtonStyle}"
                                            Content="Скасувати"
                                            Command="{Binding CancelCommand}" />
                                    <Button Grid.Column="3"
                                            Style="{StaticResource RegisterButtonStyle}"
                                            Content="{Binding RegisterButtonText}"
                                            Command="{Binding RegisterCommand}" />
                                    <Button Grid.Column="5"
                                            Style="{StaticResource LoginButtonStyle}"
                                            Content="Увійти"
                                            IsDefault="True"
                                            Command="{Binding LoginCommand}" />
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
