<UserControl x:Class="CarRental.Desktop.Views.Pages.ClientsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="ClientsRoot" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="ClientsOverviewCard"
                Grid.Row="0"
                Margin="0,0,0,12"
                Style="{StaticResource CardSurfaceStyle}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="База клієнтів (CRM)" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="Оберіть клієнта в таблиці, щоб переглянути деталі та виконати дії справа."
                               Style="{StaticResource SectionHintStyle}" />
                </StackPanel>
                <Button x:Name="ClientsRefreshButton"
                        DockPanel.Dock="Right"
                        Content="Оновити"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding RefreshCommand}" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <GroupBox x:Name="ClientsListGroup"
                      Grid.Column="0"
                      Margin="0,0,10,0"
                      Header="Список клієнтів">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="ClientsGrid"
                              Grid.Row="0"
                              ItemsSource="{Binding Clients}"
                              SelectedItem="{Binding SelectedClient}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                            <DataGridTextColumn Header="ПІБ" Binding="{Binding FullName}" Width="240" />
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="160" />
                            <DataGridTextColumn Header="Посвідчення" Binding="{Binding DriverLicense}" Width="150" />
                            <DataGridTemplateColumn Header="Статус" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeBorderStyle}">
                                                    <Setter Property="Background" Value="#DCFCE7" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Blacklisted}" Value="True">
                                                            <Setter Property="Background" Value="#FEE2E2" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource StatusBadgeTextStyle}">
                                                        <Setter Property="Text" Value="Активний" />
                                                        <Setter Property="Foreground" Value="#166534" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Blacklisted}" Value="True">
                                                                <Setter Property="Text" Value="У чорному списку" />
                                                                <Setter Property="Foreground" Value="#991B1B" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DockPanel Grid.Row="1" Margin="0,10,0,0">
                        <TextBlock DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   Foreground="#64748B"
                                   Text="{Binding PageStatusText}" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Margin="0,0,8,0"
                                    Content="Назад"
                                    Command="{Binding PreviousPageCommand}" />
                            <Button Content="Далі"
                                    Command="{Binding NextPageCommand}" />
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </GroupBox>

            <GroupBox x:Name="ClientDetailsGroup" Grid.Column="1" Header="Картка клієнта">
                <StackPanel x:Name="ClientDetailsPanel">
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" Style="{StaticResource FormLabelStyle}" Text="ID:" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedClient.Id, TargetNullValue=—}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,6" Style="{StaticResource FormLabelStyle}" Text="ПІБ:" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedClient.FullName, TargetNullValue=—}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,6" Style="{StaticResource FormLabelStyle}" Text="Телефон:" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedClient.Phone, TargetNullValue=—}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource FormLabelStyle}" Text="Посвідчення:" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedClient.DriverLicense, TargetNullValue=—}" />
                    </Grid>

                    <TextBlock Text="Дії"
                               Style="{StaticResource SectionTitleStyle}"
                               FontSize="15"
                               Margin="0,0,0,10" />
                    <Button x:Name="ToggleBlacklistButton"
                            Content="Додати/прибрати зі списку"
                            Margin="0,0,0,8"
                            Command="{Binding ToggleBlacklistCommand}" />
                    <Button x:Name="DeleteClientButton"
                            Content="Видалити клієнта"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding DeleteClientCommand}" />
                </StackPanel>
            </GroupBox>
        </Grid>

        <Border x:Name="ClientsStatusPanel"
                Grid.Row="2"
                Margin="0,12,0,0"
                Style="{StaticResource StatusPanelStyle}">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
        </Border>

        <Border x:Name="GuideOverlay"
                Grid.RowSpan="3"
                Background="Transparent"
                Visibility="Collapsed"
                Panel.ZIndex="1200"
                MouseLeftButtonDown="GuideOverlay_OnMouseLeftButtonDown">
            <Canvas>
                <Rectangle x:Name="GuideDimTop" Fill="#A8000000" IsHitTestVisible="False" />
                <Rectangle x:Name="GuideDimLeft" Fill="#A8000000" IsHitTestVisible="False" />
                <Rectangle x:Name="GuideDimRight" Fill="#A8000000" IsHitTestVisible="False" />
                <Rectangle x:Name="GuideDimBottom" Fill="#A8000000" IsHitTestVisible="False" />

                <Border x:Name="GuideHighlightBorder"
                        BorderBrush="#34D399"
                        BorderThickness="2"
                        CornerRadius="10"
                        Background="#18FFFFFF"
                        IsHitTestVisible="False" />

                <Border x:Name="GuideCard"
                        Width="350"
                        Padding="12"
                        Background="White"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="12"
                        IsHitTestVisible="False">
                    <StackPanel>
                        <TextBlock Text="Гайд: Клієнти"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A" />
                        <TextBlock x:Name="GuideStepTitle"
                                   Margin="0,8,0,4"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <TextBlock x:Name="GuideStepDescription"
                                   Foreground="#475569"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="GuideStepProgress"
                                   Margin="0,8,0,0"
                                   Foreground="#6B7280"
                                   FontSize="12" />
                    </StackPanel>
                </Border>
            </Canvas>
        </Border>
    </Grid>
</UserControl>
