<UserControl x:Class="CarRental.Desktop.Views.Pages.AdminPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0F766E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#115E59" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0D9488" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#94A3B8" />
                    <Setter Property="BorderBrush" Value="#94A3B8" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5F9" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F1F5F9" />
                    <Setter Property="Foreground" Value="#94A3B8" />
                    <Setter Property="BorderBrush" Value="#E2E8F0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#E2E8F0" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusKind}" Value="Success">
                    <Setter Property="Background" Value="#DCFCE7" />
                    <Setter Property="BorderBrush" Value="#86EFAC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusKind}" Value="Error">
                    <Setter Property="Background" Value="#FEE2E2" />
                    <Setter Property="BorderBrush" Value="#FCA5A5" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="AdminScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid x:Name="AdminRoot" Margin="8" Background="#F8FAFC">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="AdminHeaderCard" Grid.Row="0" Style="{StaticResource FilterCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
                        <TextBlock Text="Панель адміністратора"
                                   Style="{StaticResource FilterHeaderTextStyle}" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="Керуйте працівниками, ролями та безпекою облікових записів."
                                   Style="{StaticResource FilterSubtleTextStyle}" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,14,0,0"
                            Style="{StaticResource FilterSectionStyle}">
                        <StackPanel>
                            <TextBlock Text="Пошук у списку працівників"
                                       Style="{StaticResource FormLabelStyle}" />
                            <TextBox x:Name="EmployeeFilterTextBox"
                                     Width="280"
                                     VerticalContentAlignment="Center"
                                     Padding="8,4"
                                     Text="{Binding FilterQuery, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding StatusMessage}"
                                       Foreground="#475569"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel x:Name="SearchAndRefreshPanel"
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="16,14,0,0"
                                Style="{StaticResource FilterActionBarStyle}">
                        <Button x:Name="RefreshEmployeesButton"
                                Content="Оновити список"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0"
                                Padding="14,8" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="AdminMetricsGrid" Grid.Row="1" Margin="0,12,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardBorderStyle}"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Всього працівників" Foreground="#64748B" FontSize="12" />
                        <TextBlock Text="{Binding TotalEmployees}" Foreground="#0F172A" FontWeight="Bold" FontSize="28" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="8,0">
                    <StackPanel>
                        <TextBlock Text="Активні" Foreground="#64748B" FontSize="12" />
                        <TextBlock Text="{Binding ActiveEmployees}" Foreground="#166534" FontWeight="Bold" FontSize="28" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="8,0">
                    <StackPanel>
                        <TextBlock Text="Менеджери" Foreground="#64748B" FontSize="12" />
                        <TextBlock Text="{Binding ManagersCount}" Foreground="#1D4ED8" FontWeight="Bold" FontSize="28" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource CardBorderStyle}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Заблоковані" Foreground="#64748B" FontSize="12" />
                        <TextBlock Text="{Binding LockedEmployees}" Foreground="#B91C1C" FontWeight="Bold" FontSize="28" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="AdminWorkspaceGrid" Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="EmployeesListCard"
                        Grid.Column="0"
                        Style="{StaticResource CardBorderStyle}"
                        Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="Працівники"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />
                            <TextBlock DockPanel.Dock="Right"
                                       Foreground="#64748B"
                                       VerticalAlignment="Center"
                                       Text="{Binding VisibleEmployeesCount, StringFormat=Відображено: {0}}" />
                        </DockPanel>

                        <DataGrid x:Name="EmployeesGrid"
                                  Grid.Row="1"
                                  ItemsSource="{Binding EmployeesView}"
                                  SelectedItem="{Binding SelectedEmployee}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  AlternatingRowBackground="#F8FAFC"
                                  BorderThickness="0"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ПІБ" Binding="{Binding FullName}" Width="1.5*" />
                                <DataGridTextColumn Header="Логін" Binding="{Binding Login}" Width="*" />
                                <DataGridTextColumn Header="Роль" Binding="{Binding RoleDisplay}" Width="*" />
                                <DataGridTemplateColumn Header="Стан" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,3" CornerRadius="10" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#DCFCE7" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Background" Value="#FEE2E2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding ActivityDisplay}" FontWeight="SemiBold" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#166534" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Foreground" Value="#B91C1C" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Блокування до" Binding="{Binding LockoutDisplay}" Width="1.2*" />
                                <DataGridTextColumn Header="Останній вхід" Binding="{Binding LastLoginDisplay}" Width="1.2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1">
                    <Border x:Name="EmployeeActionsCard" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Дії з працівником" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" />
                            <TextBlock Text="{Binding ActionHint}" Margin="0,8,0,12" Foreground="#475569" TextWrapping="Wrap" />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" Foreground="#64748B" Text="Працівник:" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" Foreground="#0F172A" FontWeight="SemiBold" Text="{Binding SelectedEmployeeDisplayName}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,6" Foreground="#64748B" Text="Роль:" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Foreground="#0F172A" Text="{Binding SelectedEmployeeRoleDisplay}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,6" Foreground="#64748B" Text="Стан:" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Foreground="#0F172A" Text="{Binding SelectedEmployeeStateDisplay}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,0" Foreground="#64748B" Text="Блокування:" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Foreground="#0F172A" Text="{Binding SelectedEmployeeLockoutDisplay}" />
                            </Grid>

                            <Button Content="{Binding ToggleActiveActionLabel}" Command="{Binding ToggleActiveCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="{Binding ToggleManagerRoleActionLabel}" Command="{Binding ToggleManagerRoleCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="Розблокувати / скинути спроби входу"
                                    Command="{Binding UnlockCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,0,0" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="PasswordChangeCard" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Зміна мого пароля" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A" />
                            <TextBlock Margin="0,6,0,12"
                                       Foreground="#64748B"
                                       Text="Для безпеки використовуйте новий пароль, який не повторює старий." />

                            <TextBlock Text="Поточний пароль" Foreground="#334155" />
                            <PasswordBox x:Name="CurrentPasswordBox"
                                         Margin="0,4,0,10"
                                         Height="34"
                                         Padding="8,4"
                                         PasswordChanged="CurrentPasswordBox_OnPasswordChanged" />

                            <TextBlock Text="Новий пароль" Foreground="#334155" />
                            <PasswordBox x:Name="NewPasswordBox"
                                         Margin="0,4,0,12"
                                         Height="34"
                                         Padding="8,4"
                                         PasswordChanged="NewPasswordBox_OnPasswordChanged" />

                            <Button Content="Змінити пароль"
                                    Command="{Binding ChangePasswordCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Border x:Name="AdminStatusPanel"
                    Grid.Row="3"
                    Margin="0,12,0,0"
                    Padding="12,10"
                    Style="{StaticResource StatusBorderStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               Margin="0,0,8,0"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               Text="Статус:" />
                    <TextBlock Foreground="#0F172A" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                    <TextBlock DockPanel.Dock="Right" Foreground="#64748B" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="" />
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Text" Value="Завантаження..." />
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DockPanel>
            </Border>

            <Border x:Name="GuideOverlay"
                    Grid.RowSpan="4"
                    Background="Transparent"
                    Visibility="Collapsed"
                    Panel.ZIndex="1200"
                    MouseLeftButtonDown="GuideOverlay_OnMouseLeftButtonDown">
                <Canvas>
                    <Rectangle x:Name="GuideDimTop" Fill="#A8000000" IsHitTestVisible="False" />
                    <Rectangle x:Name="GuideDimLeft" Fill="#A8000000" IsHitTestVisible="False" />
                    <Rectangle x:Name="GuideDimRight" Fill="#A8000000" IsHitTestVisible="False" />
                    <Rectangle x:Name="GuideDimBottom" Fill="#A8000000" IsHitTestVisible="False" />

                    <Border x:Name="GuideHighlightBorder"
                            BorderBrush="#34D399"
                            BorderThickness="2"
                            CornerRadius="10"
                            Background="#18FFFFFF"
                            IsHitTestVisible="False" />

                    <Border x:Name="GuideCard"
                            Width="360"
                            Padding="12"
                            Background="White"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="12"
                            IsHitTestVisible="False">
                        <StackPanel>
                            <TextBlock Text="Гайд: Адміністрування"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />
                            <TextBlock x:Name="GuideStepTitle"
                                       Margin="0,8,0,4"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#111827" />
                            <TextBlock x:Name="GuideStepDescription"
                                       Foreground="#475569"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="GuideStepProgress"
                                       Margin="0,8,0,0"
                                       Foreground="#6B7280"
                                       FontSize="12" />
                        </StackPanel>
                    </Border>
                </Canvas>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>

