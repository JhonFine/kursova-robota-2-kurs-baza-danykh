<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="CarRental.Desktop.Views.Pages.FleetPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>
    <Grid x:Name="FleetRoot" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,12">
            <Border x:Name="FleetFiltersCard" Style="{StaticResource FilterCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,12">
                        <TextBlock Text="Фільтри автопарку" Style="{StaticResource FilterHeaderTextStyle}" />
                        <TextBlock Text="Комбінуйте швидкі фільтри, а деталізований пошук відкривайте окремою панеллю."
                                   Style="{StaticResource FilterSubtleTextStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Марка" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox MinWidth="170"
                                  ItemsSource="{Binding MakeFilterOptions}"
                                  SelectedItem="{Binding SelectedMakeFilter}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Клас авто" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox MinWidth="170"
                                  ItemsSource="{Binding ClassFilterOptions}"
                                  SelectedItem="{Binding SelectedClassFilter}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2">
                        <TextBlock Text="Статус" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox MinWidth="170"
                                  ItemsSource="{Binding StatusFilterOptions}"
                                  SelectedItem="{Binding SelectedStatusFilter}" />
                    </StackPanel>

                    <Button x:Name="SearchToggleButton"
                            Grid.Row="1"
                            Grid.Column="3"
                            MinWidth="150"
                            Height="40"
                            Margin="12,18,8,0"
                            Padding="14,8"
                            Content="Пошук і запит"
                            ToolTip="Відкрити панель швидкого пошуку"
                            Command="{Binding ToggleSearchPanelCommand}" />

                    <StackPanel Grid.Row="2"
                                Grid.Column="0"
                                Grid.ColumnSpan="2"
                                Margin="0,14,0,0">
                        <TextBlock Foreground="#64748B"
                                   Text="{Binding PageStatusText}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#475569"
                                   Text="{Binding StatusMessage}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               Grid.ColumnSpan="2"
                               Margin="12,14,8,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="#64748B"
                               FontSize="12"
                               Text="Деталі авто доступні кнопкою нижче або подвійним кліком." />
                </Grid>
            </Border>

            <Border x:Name="SearchPanelCard"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,54,20,0"
                    Width="320"
                    Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform X="36" />
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource FilterSectionStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSearchPanelOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             Duration="0:0:0.14" />
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             From="36"
                                                             To="0"
                                                             Duration="0:0:0.16" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Деталізований пошук"
                               Style="{StaticResource FilterHeaderTextStyle}" />
                    <TextBlock Text="Використовуйте конкретне поле, якщо швидких фільтрів недостатньо."
                               Style="{StaticResource FilterSubtleTextStyle}" />

                    <TextBlock Margin="0,12,0,0" Text="Поле" Style="{StaticResource FormLabelStyle}" />
                    <ComboBox Margin="0,0,0,6"
                              ItemsSource="{Binding SearchFieldOptions}"
                              DisplayMemberPath="Label"
                              SelectedItem="{Binding SelectedSearchField}" />

                    <TextBlock Text="Значення" Style="{StaticResource FormLabelStyle}" />
                    <TextBox Margin="0,0,0,8"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <UniformGrid Columns="2" Margin="0,4,0,0">
                        <Button Margin="0,0,6,0"
                                Content="Знайти"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SearchCommand}" />
                        <Button Content="Очистити"
                                Command="{Binding ClearSearchCommand}" />
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>

        <GroupBox x:Name="FleetListGroup"
                  Grid.Row="1"
                  Header="Список авто">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DataGrid x:Name="VehiclesGrid"
                          Grid.Row="0"
                          ItemsSource="{Binding Vehicles}"
                          SelectedItem="{Binding SelectedVehicle}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding OpenVehicleDetailsCommand}" />
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                        <DataGridTextColumn Header="Авто" Binding="{Binding Car}" Width="220" />
                        <DataGridTextColumn Header="Клас" Binding="{Binding CarClass}" Width="130" />
                        <DataGridTextColumn Header="Номер" Binding="{Binding LicensePlate}" Width="130" />
                        <DataGridTextColumn Header="Пробіг" Binding="{Binding Mileage}" Width="100" />
                        <DataGridTextColumn Header="Ціна/доба" Binding="{Binding DailyRate}" Width="120" />
                        <DataGridTextColumn Header="Інтервал ТО" Binding="{Binding ServiceIntervalKm}" Width="130" />
                        <DataGridTemplateColumn Header="Статус" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StatusBadgeBorderStyle}"
                                            Background="{Binding Status, Converter={StaticResource StatusBadgeBackgroundConverter}}">
                                        <TextBlock Style="{StaticResource StatusBadgeTextStyle}"
                                                   Text="{Binding Status}"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusBadgeForegroundConverter}}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <DockPanel Grid.Row="1" Margin="0,10,0,0">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#64748B"
                                   Text="{Binding PageStatusText}" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Обране авто:"
                                       Foreground="#475569"
                                       FontWeight="SemiBold"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="{Binding SelectedVehicle.Car, TargetNullValue=—}"
                                       Foreground="#0F172A"
                                       FontWeight="SemiBold"
                                       Margin="0,0,8,0" />
                            <Border Style="{StaticResource StatusBadgeBorderStyle}"
                                    Background="{Binding SelectedVehicle.Status, Converter={StaticResource StatusBadgeBackgroundConverter}}">
                                <TextBlock Style="{StaticResource StatusBadgeTextStyle}"
                                           Text="{Binding SelectedVehicle.Status, TargetNullValue=Не обрано}"
                                           Foreground="{Binding SelectedVehicle.Status, Converter={StaticResource StatusBadgeForegroundConverter}}" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Margin="0,0,8,0"
                                Content="Деталі авто"
                                Command="{Binding OpenVehicleDetailsCommand}" />
                        <Button Margin="0,0,8,0"
                                Content="Назад"
                                Command="{Binding PreviousPageCommand}" />
                        <Button Content="Далі"
                                Command="{Binding NextPageCommand}" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </GroupBox>

        <GroupBox x:Name="FleetAddGroup"
                  Grid.Row="2"
                  Header="Додавання авто">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           Width="620"
                           Style="{StaticResource SectionHintStyle}"
                           Margin="0"
                           Text="Натисніть кнопку праворуч, щоб відкрити детальну форму нового автомобіля та додати фото." />

                <Button DockPanel.Dock="Right"
                        Width="150"
                        Margin="8,0,0,0"
                        Content="Додати авто"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsEnabled="{Binding CanManageFleet}"
                        Click="AddVehicleButton_OnClick" />
            </DockPanel>
        </GroupBox>

        <Border Grid.RowSpan="3"
                Background="#99000000"
                Visibility="{Binding IsVehicleDetailsDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="980"
                        MaxHeight="620"
                        Background="White"
                        CornerRadius="10"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding SelectedVehicle.Car, TargetNullValue=Деталі авто}"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="#0F172A" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#475569"
                                           Text="Перевірте стан автомобіля і, за потреби, оновіть тариф." />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="✕"
                                    Width="34"
                                    Height="30"
                                    FontSize="16"
                                    Command="{Binding CloseVehicleDetailsCommand}" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" Style="{StaticResource FormLabelStyle}" Text="Авто:" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedVehicle.Car, TargetNullValue=—}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,6" Style="{StaticResource FormLabelStyle}" Text="Номер:" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedVehicle.LicensePlate, TargetNullValue=—}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,6" Style="{StaticResource FormLabelStyle}" Text="Пробіг:" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedVehicle.Mileage, TargetNullValue=—}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,6" Style="{StaticResource FormLabelStyle}" Text="Інтервал ТО:" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" Text="{Binding SelectedVehicle.ServiceIntervalKm, TargetNullValue=—}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource FormLabelStyle}" Text="Статус:" />
                                    <Border Grid.Row="4"
                                            Grid.Column="1"
                                            Style="{StaticResource StatusBadgeBorderStyle}"
                                            Background="{Binding SelectedVehicle.Status, Converter={StaticResource StatusBadgeBackgroundConverter}}">
                                        <TextBlock Style="{StaticResource StatusBadgeTextStyle}"
                                                   Text="{Binding SelectedVehicle.Status, TargetNullValue=—}"
                                                   Foreground="{Binding SelectedVehicle.Status, Converter={StaticResource StatusBadgeForegroundConverter}}" />
                                    </Border>
                                </Grid>

                                <Border Padding="12"
                                        Background="#F8FAFC"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="Оновлення тарифу"
                                                   Style="{StaticResource SectionTitleStyle}"
                                                   FontSize="15"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource FormLabelStyle}" Text="Нова ціна за добу" Margin="0,10,0,4" />
                                        <TextBox Text="{Binding NewDailyRate, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Content="Оновити ціну"
                                                Margin="0,12,0,0"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                IsEnabled="{Binding CanUpdatePricing}"
                                                Command="{Binding UpdateRateCommand}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="8"
                                    Background="#F8FAFC"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <Grid>
                                    <Image Source="{Binding SelectedVehicle.ImageSource, Converter={StaticResource VehiclePhotoSourceConverter}, ConverterParameter=detail}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedVehicle.HasImage, FallbackValue=False, TargetNullValue=False}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>

                                    <TextBlock Text="Фото недоступне"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               Margin="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedVehicle.HasImage, FallbackValue=False, TargetNullValue=False}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="GuideOverlay"
                Grid.RowSpan="3"
                Background="Transparent"
                Visibility="Collapsed"
                Panel.ZIndex="1200"
                MouseLeftButtonDown="GuideOverlay_OnMouseLeftButtonDown">
            <Canvas>
                <Rectangle x:Name="GuideDimTop" Fill="#A8000000" IsHitTestVisible="False" />
                <Rectangle x:Name="GuideDimLeft" Fill="#A8000000" IsHitTestVisible="False" />
                <Rectangle x:Name="GuideDimRight" Fill="#A8000000" IsHitTestVisible="False" />
                <Rectangle x:Name="GuideDimBottom" Fill="#A8000000" IsHitTestVisible="False" />

                <Border x:Name="GuideHighlightBorder"
                        BorderBrush="#34D399"
                        BorderThickness="2"
                        CornerRadius="10"
                        Background="#18FFFFFF"
                        IsHitTestVisible="False" />

                <Border x:Name="GuideCard"
                        Width="350"
                        Padding="12"
                        Background="White"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="12"
                        IsHitTestVisible="False">
                    <StackPanel>
                        <TextBlock Text="Гайд: Автопарк"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A" />
                        <TextBlock x:Name="GuideStepTitle"
                                   Margin="0,8,0,4"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <TextBlock x:Name="GuideStepDescription"
                                   Foreground="#475569"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="GuideStepProgress"
                                   Margin="0,8,0,0"
                                   Foreground="#6B7280"
                                   FontSize="12" />
                    </StackPanel>
                </Border>
            </Canvas>
        </Border>
    </Grid>
</UserControl>
